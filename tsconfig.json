{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["vitepress/client"],
    "skipLibCheck": true
  },
  "include": ["docs/.vitepress/**/*.ts", "docs/**/*.vue"]
}
